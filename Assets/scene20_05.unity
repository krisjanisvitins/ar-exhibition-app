  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Ieteikumi GLB failu optimiz\u0101cijai:\n- Triangles vienam modelim l\u012Bdz
    ~25'000\n- Triangles kop\u0101 sc\u0113n\u0101 l\u012Bdz ~250'000 \n- Faila izm\u0113rs
    vienam modelim l\u012Bdz ~10 MB\n- Kop\u0113jais failu izm\u0113rs sc\u0113n\u0101
    l\u012Bdz ~100 MB\n- Tekst\u016Bru iz\u0161\u0137irtsp\u0113ja modelim l\u012Bdz
    2048x2048\n- Materi\u0101lu skaits uz modeli: l\u012Bdz 10\n- Mesh skaits uz
    materi\u0101lu: 1\n- UV skaits uz vienu mesh: 1\n\nVeidot\u0101js: \n- Apstipriniet
    lieto\u0161anas noteikumus\n- Iel\u0101d\u0113jiet visus .glb failus, kurus izvietosiet\n-
    L\u0113n\u0101m kustiniet kameru telp\u0101 un skatieties apk\u0101rt l\u012Bdz
    plaknes tiek atpaz\u012Btas\n- Novietojiet divus atsauces punktiem uz zemes (p\u0113c
    iesp\u0113jas t\u0101l\u0101k vienu no otra)\n- Izvietojiet un manipul\u0113jiet
    objektus\n- Saglab\u0101jiet izst\u0101di un t\u0101s failu nododiet skat\u012Bt\u0101jam\n\nSkat\u012Bt\u0101js:\n-
    Izv\u0113lieties izst\u0101des failu no ier\u012Bces atmi\u0146as\n- L\u0113n\u0101m
    kustiniet kameru telp\u0101 un skatieties apk\u0101rt l\u012Bdz plaknes tiek
    atpaz\u012Btas\n- Pieskarieties izst\u0101des veidot\u0101ja nor\u0101d\u012Btiem
    diviem atsauces punktiem uz zemes"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
